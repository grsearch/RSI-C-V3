# ── API Keys ─────────────────────────────────────────────────────
BIRDEYE_API_KEY=                   # B-05 级别，支持 WebSocket 实时价格推送

# ── Helius 配置（Business 级别） ──────────────────────────────────
#
# ★ WebSocket 连接优先级（用于链上交易监听）：
#   Gatekeeper WSS (beta) > HELIUS_WSS_URL > 自动拼接
#
# ★ LaserStream 是 gRPC 协议，不是 WebSocket！
#   仅用于 trader.js 的 RPC 发单加速，不能用于 transactionSubscribe。
#   如果只配置了 LaserStream 而没配 WSS_URL，程序会自动用 API Key 拼接 WSS 端点。
#
# Enhanced WebSocket（链上交易监听 — 必须配置）
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
#
# Gatekeeper（beta — WebSocket 最低延迟，同时也用于 RPC 发单）
HELIUS_GATEKEEPER_URL=https://beta.helius-rpc.com/?api-key=YOUR_KEY
#
# LaserStream（gRPC，仅用于 RPC 发单加速，不用于 WebSocket 订阅）
# HELIUS_LASERSTREAM_URL=https://laserstream-mainnet-fra.helius-rpc.com
#
# 标准 RPC（兜底）
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=                    # 备用，如果上面 URL 中已含 api-key 可不填
#
# ★ WebSocket 订阅模式（影响 credits 消耗和稳定性）
#   "multi" = ★推荐★ 所有 mint 合并成一个 transactionSubscribe，只占 1 个订阅 slot。
#             彻底规避 Helius 多订阅丢单问题，适合所有 DEX 混合场景。
#   "token" = 每 mint 一个独立订阅。credits 最省，但多订阅可能丢单（不推荐）。
#   "pump"  = 一个 accountInclude:[PumpAMM] 全局订阅。credits 消耗大，仅适合全部是 Pump 代币。
#   "auto"  = 代币数 ≤ HELIUS_TOKEN_LIMIT 用 token，超过自动切 pump（会漏非 Pump 代币）。
HELIUS_SUB_MODE=multi
HELIUS_TOKEN_LIMIT=50
# multi 模式：add/remove token 后延迟多久重发订阅（防抖）
HELIUS_MULTI_DEBOUNCE_MS=500
# ★ multi 模式：每个订阅最多包含的 mint 数。超过自动拆批并行订阅。
#   Helius 实测超过 ~60 个会返回 Internal error / Invalid Request，故保守值 50。
#   如果你有更大规模需求可以实测调大（55/60），调大后若出现订阅失败再调回。
HELIUS_MAX_MINTS_PER_SUB=50

# ── Jupiter ──────────────────────────────────────────────────────
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=

# ── 钱包 ─────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=                # Base58 私钥（DRY_RUN 模式下可留空）

# ── 交易参数 ──────────────────────────────────────────────────────
TRADE_SIZE_SOL=0.2
SLIPPAGE_BPS=500                   # 默认滑点（bps）
SLIPPAGE_MAX_BPS=2000              # 最大滑点（重试时递增）
TRADE_MAX_RETRY=3                  # 交易重试次数（止损时自动减少）
PRIORITY_FEE_MICROLAMPORTS=100000  # 默认 priority fee（动态获取失败时的兜底值）

# ── 策略参数 ──────────────────────────────────────────────────────
RSI_PERIOD=7                       # ★ RSI周期（改为7，更灵敏）
RSI_BUY_LEVEL=35                   # RSI < 此值 + 量能确认 → 买入
RSI_SELL_LEVEL=70                   # RSI 下穿此值 → 卖出
RSI_PANIC_LEVEL=80                  # RSI > 此值 → 立即卖出

# ── 量能过滤参数 ──────────────────────────────────────────────────
VOL_ENABLED=true                   # 是否启用量能过滤
VOL_BUY_MULT=1.2                   # 买入条件：buyVol >= N × sellVol
VOL_SELL_MULT=999                  # 卖压卖出倍数（999=禁用，不按卖压卖出）
VOL_MIN_TOTAL=5                    # 买入条件：窗口内总成交量(buyVol+sellVol) >= N SOL
VOL_WINDOW_SEC=300                 # ★ 量能窗口（5分钟，与K线宽度独立）
VOL_EXIT_CONSECUTIVE=3             # 持仓中连续N根K线量能萎缩则出场
VOL_EXIT_RATIO=0.3                 # 量能萎缩阈值: 最近 N 根均量 < 前 LOOKBACK 根均量 × 0.3 (30%, 严重萎缩才触发)
VOL_EXIT_LOOKBACK=4                # 萎缩出场均量回看K线数
VOL_DECAY_EXIT_ENABLED=true        # ★ V5-26: 量能萎缩出场总开关 (默认启用)
SKIP_FIRST_CANDLES=3               # ★ 跳过前N根K线不交易（1分钟×3=3分钟预热）
# ★ RSI/EMA 收敛门槛：低于此K线数完全不产生买卖信号（避免指标不收敛误判）
#    默认 max(SKIP_FIRST_CANDLES, RSI_PERIOD × 3) = 21，Wilder RSI 收敛所需
#    建议不要设低于 21；若要求 EMA99 稳定建议设到 99 或更高
MIN_CANDLES_FOR_SIGNAL=21

# ── K线 & 轮询 ────────────────────────────────────────────────────
KLINE_INTERVAL_SEC=60              # ★ K线宽度（1分钟K线）
PRICE_POLL_SEC=1                   # 价格轮询间隔（秒）
SL_POLL_SEC=60                     # 止盈止损轮询间隔（秒）

# ── FDV/LP 缓存时间（毫秒，默认30分钟，买入前会强制刷新）─────
FDV_CACHE_MS=1800000               # ★ V5: 1800000ms = 30分钟缓存（买入前getFdvFresh强制刷新）

TAKE_PROFIT_PCT=100                # 止盈百分比（+100% 时卖出，仅在 TAKE_PROFIT_ENABLED=true 时生效）
TAKE_PROFIT_ENABLED=true           # ★ 固定止盈总开关（默认开启，+100% 止盈）
STOP_LOSS_PCT=-50                  # 固定止损百分比（负数，仅在 STOP_LOSS_ENABLED=true 时生效）
STOP_LOSS_ENABLED=true             # ★ V5-26: 固定止损总开关 (默认启用 -50%)
# ★ 止损执行路径：Birdeye WS 价格推送（<150ms）→ 本地判断 → Helius Sender（<350ms）
#    总延迟目标 <500ms

# ── 移动止损（Trailing Stop）──────────────────────────────────────
TRAILING_STOP_ENABLED=true         # 是否开启移动止损
TRAILING_STOP_ACTIVATE=30          # 上涨达到此幅度(%)后激活移动止损
TRAILING_STOP_PCT=-20              # 从峰值回撤超过此幅度(%)则清仓

# ── 监控参数 ──────────────────────────────────────────────────────
SELL_COOLDOWN_SEC=1800             # 卖出后冷却时间（秒），默认30分钟，防止同一代币重复买入
MAX_HOLD_SEC=21600                 # ★ V5-21 最大持仓时间(秒), 默认 21600=6小时, 0=关闭
                                   # 防止僵持币长期占用资金, 超时强制卖出, reason=TIMEOUT_EXIT
HIST_BARS=150                      # 新代币加入时从Birdeye拉取的历史K线根数（用于EMA99/RSI预热，150根1分钟≈2.5小时；如需更稳的EMA99可调到300+）
# ★ V5-16: 实时 OHLCV 刷新（替代不准的 ticks 聚合）
#   开启后，主轮询里 K 线源直接用 Birdeye OHLCV API（每 OHLCV_REFRESH_SEC 秒拉一次），
#   保证 K 线序列和 GMGN 等使用 Birdeye 数据源的工具一致。
#   量能字段（buyVolume/sellVolume）依然来自 Helius 链上交易聚合，不受影响。
OHLCV_REALTIME_ENABLED=true        # 默认开启
OHLCV_REFRESH_SEC=30               # ★ V5-32: 1分钟K线下改 30s, 让 closed candle 更勤滚动
                                   # 配合 monitor.js 的 orphan-bucket 合并逻辑, 避免链上量能丢失
                                   # 实时价格走 Birdeye WS SUBSCRIBE_PRICE, 不影响信号时效
                                   # 不建议设小于 30, 会快速烧光月度 CU 配额
OHLCV_REALTIME_BARS=120            # 实时刷新拉的K线根数（够算 EMA99 即可）
# ★ 历史K线拉取队列：避免 Birdeye 429 限流
HIST_FETCH_GAP_MS=1200             # 每次拉取请求之间的间隔(毫秒)，越大越不容易被限流
HIST_RETRY_MAX=5                   # 拉取失败(429/超时)时最大重试次数
HIST_RETRY_BASE_MS=5000            # 重试退避基准(毫秒)，实际等待 = base × 2^(attempt-1)
# ★ Birdeye 价格请求失败抑制（避免 HTTP 400/404/超时 每秒刷屏日志）
PRICE_HTTP_CACHE_MS=60000          # 成功拉取的价格缓存多久（毫秒），默认60秒
PRICE_FAIL_PERM_TTL_MS=300000      # 永久错误(400/404)静默多久（毫秒），默认5分钟
PRICE_FAIL_TEMP_TTL_MS=30000       # 临时错误(429/5xx/超时)静默多久（毫秒），默认30秒
PRICE_FAIL_LOG_GAP_MS=60000        # 同一 address 同一错误的日志去重间隔（毫秒），默认1分钟
# ★ V5-15: WS tick 实时 RSI 下穿检测的 prevRsi 时效（毫秒）
#   Birdeye WS 偶尔断流几十秒再恢复时，如果直接和旧 prevRsi 比较会产生虚假下穿。
#   超过此时间视为失效，跳过本次判断，重建 baseline。
#   默认 3000 (3秒) —— 正常情况下 Birdeye WS 每秒都有 tick，3 秒已经很宽松。
WS_RSI_PREV_STALE_MS=3000
EMA_PERIOD=99                      # EMA周期（用于斜率过滤；0=完全关闭EMA相关过滤）
# ★ EMA99 价格过滤总开关（价格必须在 EMA99 下方才允许买入）
#    true  = 启用（默认行为，多头趋势中的回调买入）
#    false = 关闭（不再要求价格 < EMA99，只看斜率方向）
EMA_PRICE_FILTER_ENABLED=false
# ★ EMA99 不足时的行为（K线 < EMA_PERIOD 根时）
#    strict  = 拒绝买入（推荐，避免新币/数据不足时误买）
#    lenient = 跳过 EMA99 过滤（旧行为，有漏洞，不推荐）
EMA_INSUFFICIENT_MODE=strict
# ★ V6: EMA99 斜率过滤 —— 拒绝在 EMA99 下行趋势中买入（"接飞刀"防护）
#   slope = (EMA99_now - EMA99_lookback前) / EMA99_lookback前
#   slope < EMA_SLOPE_MIN_PCT → 拒绝买入
EMA_SLOPE_ENABLED=true
EMA_SLOPE_LOOKBACK=10              # 回看K线根数（10根×1分钟K线=10分钟窗口）
EMA_SLOPE_MIN_PCT=-2               # 斜率下限(%)，斜率 ≥ -2% 才允许买入（容忍轻微下行）
FDV_EXIT_USD=20000                 # FDV低于此值退出监控（$20000）
LP_EXIT_USD=10000                  # LP低于此值退出监控（$10000）
MIN_FDV_USD=15000                  # Webhook接入时最低FDV门槛
MIN_LP_USD=5000                    # Webhook接入时最低LP门槛
MAX_MONITOR_TOKENS=95              # ★ V5: 最大监控代币数，满时自动清理最不活跃的
OVERVIEW_PATROL_SEC=7200           # ★ V5: FDV/LP/Age巡检间隔（秒，默认2小时）

# ── 空跑模式 ──────────────────────────────────────────────────────
DRY_RUN=true                       # true=不实际交易，只记录信号和模拟盈亏
# ★ 数据目录放在项目外面，更新代码时不会丢失代币列表和交易数据
# deploy.sh 会自动设置为 ~/sol-monitor-data
DRY_RUN_DATA_DIR=/root/sol-monitor-data

# ── 服务器 ────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info

# ── X (Twitter) Mentions 24h 计数 (V5-18) ─────────────────────
# 用 X API v2 GET /2/tweets/counts/recent 拉取过去 24 小时内
# 包含某代币合约地址的推文总数。每 X_MENTIONS_INTERVAL_SEC 秒刷新一次。
# 没有 X_BEARER_TOKEN 时模块整体禁用,前端 X提及 列显示 -
X_BEARER_TOKEN=                    # X (Twitter) Developer API Bearer Token
X_MENTIONS_INTERVAL_SEC=7200       # 刷新间隔 (秒), 默认 2 小时
X_MENTIONS_REQUEST_GAP_SEC=15      # 串行请求间隔 (秒), 默认 15s
                                   # X API 限制 300/15min = 平均 3s/请求
                                   # 15s/请求 = 240次/小时, 完全在限额内
X_MENTIONS_TIMEOUT_MS=10000        # 单次 HTTP 超时 (毫秒)
